<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.{{DONO_SLUG}}.ademir-tunnel</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/autossh</string>
        <string>-M</string>
        <string>0</string>
        <string>-N</string>
        <string>-T</string>
        <string>-i</string>
        <string>/Users/naiarodrigues/.ssh/{{DONO_SLUG}}_key</string>
        <string>-o</string>
        <string>StrictHostKeyChecking=no</string>
        <string>-o</string>
        <string>ServerAliveInterval=15</string>
        <string>-o</string>
        <string>ServerAliveCountMax=3</string>
        <string>-o</string>
        <string>ExitOnForwardFailure=no</string>
        <string>-o</string>
        <string>TCPKeepAlive=yes</string>
        <string>-o</string>
        <string>ConnectTimeout=20</string>
        <string>-L</string>
        <string>15432:127.0.0.1:5432</string>
        <string>-R</string>
        <string>9100:127.0.0.1:9100</string>
        <string>root@{{VPS_IP}}</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>AUTOSSH_GATETIME</key>
        <string>0</string>
        <key>AUTOSSH_POLL</key>
        <string>30</string>
        <key>AUTOSSH_FIRST_POLL</key>
        <string>15</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ExitTimeOut</key>
    <integer>10</integer>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>StandardOutPath</key>
    <string>/Users/naiarodrigues/naia-agent/logs/ademir-tunnel.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/naiarodrigues/naia-agent/logs/ademir-tunnel.log</string>
</dict>
</plist>
